---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageIntro from "../components/PageIntro.astro";
import { education, experience, thesis } from "../data/site";

const thesisLink =
  thesis.link ||
  "https://www.riss.kr/search/detail/DetailView.do?p_mat_type=be54d9b8bc7cdb09&control_no=dca174160e77311bffe0bdc3ef48d419&keyword=%EB%94%94%EC%A7%80%ED%84%B8%20%EC%97%AC%ED%96%89";
---
<BaseLayout title="Education & Experience">
  <PageIntro eyebrow="Curriculum vitae" title="Education & Experience" text="The institutions, roles, and collaborations that have shaped my research." />
  <section class="shell cv-grid">
    <div>
      <h2 class="subheading">Education</h2>
      <div class="timeline">
        {education.map((item) => (
          <article>
            <time>{item.period}</time>
            <div>
              <h3>{item.title}</h3>
              <p class="place">{item.place}</p>
              <p>{item.detail}</p>
              {item.title.startsWith("M.A.") && (
                <button class="education-link" type="button" data-open-thesis>
                  View master’s thesis →
                </button>
              )}
            </div>
          </article>
        ))}
      </div>
    </div>
    <div>
      <h2 class="subheading">Experience</h2>
      <div class="timeline">
        {experience.map((item) => (
          <article>
            <time>{item.period}</time>
            <div><h3>{item.title}</h3><p class="place">{item.place}</p><p>{item.detail}</p></div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <dialog class="thesis-dialog" data-thesis-dialog>
    <div class="thesis-dialog-head">
      <p class="eyebrow">Master’s thesis</p>
      <button type="button" class="dialog-close" data-close-thesis aria-label="Close thesis details">×</button>
    </div>
    <div class="thesis-dialog-body">
      <aside>
        <span>Study design</span>
        <strong>{thesis.method}</strong>
      </aside>
      <article>
        <h2>{thesis.title}</h2>
        <p>{thesis.summary}</p>
        <blockquote>{thesis.contribution}</blockquote>
        <a class="button primary" href={thesisLink} target="_blank" rel="noreferrer">
          Read the full thesis on RISS <span>↗</span>
        </a>
      </article>
    </div>
  </dialog>

  <script>
    const dialog = document.querySelector("[data-thesis-dialog]");
    document.querySelector("[data-open-thesis]")?.addEventListener("click", () => {
      dialog?.showModal();
    });
    document.querySelector("[data-close-thesis]")?.addEventListener("click", () => {
      dialog?.close();
    });
    dialog?.addEventListener("click", (event) => {
      if (event.target === dialog) dialog.close();
    });
  </script>
</BaseLayout>
