---
import {
  site,
  education,
  experience,
  publications,
  presentations,
  projects,
  news,
  memberships,
  methods,
  languages,
  thesis,
  blogPosts,
} from "../data/site";

const initialData = {
  site,
  education,
  experience,
  publications,
  presentations,
  projects,
  news,
  memberships,
  methods,
  languages,
  thesis,
  blogPosts,
};
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="robots" content="noindex, nofollow" />
    <title>Portfolio Editor</title>
    <style>
      :root {
        --bg: #efefe9;
        --panel: #fff;
        --ink: #111;
        --muted: #6a6a64;
        --line: #c8c8c1;
        --accent: #d8ff00;
        font-family: Arial, Helvetica, sans-serif;
      }
      * { box-sizing: border-box; }
      body { margin: 0; color: var(--ink); background: var(--bg); }
      button, input, textarea, select { font: inherit; }
      button { cursor: pointer; }
      .editor-header {
        position: sticky; top: 0; z-index: 10; min-height: 72px; padding: 14px 24px;
        display: flex; align-items: center; gap: 18px; background: var(--ink); color: white;
      }
      .editor-header h1 { margin: 0 auto 0 0; font-size: 16px; text-transform: uppercase; }
      .editor-header p { margin: 0; color: #aaa; font-size: 11px; }
      .save-button, .preview-link {
        border: 1px solid white; padding: 10px 14px; background: transparent; color: white;
        text-decoration: none; text-transform: uppercase; font-size: 11px;
      }
      .save-button { background: var(--accent); border-color: var(--accent); color: var(--ink); font-weight: 700; }
      .layout { display: grid; grid-template-columns: 230px minmax(0, 900px); gap: 42px; padding: 38px 24px 100px; }
      .sidebar { position: sticky; top: 108px; align-self: start; }
      .sidebar a {
        display: flex; justify-content: space-between; padding: 10px 0; border-bottom: 1px solid var(--line);
        color: var(--ink); text-decoration: none; font-size: 12px;
      }
      .sidebar span { color: var(--muted); }
      .editor-main { min-width: 0; }
      .notice {
        margin-bottom: 28px; padding: 18px; background: var(--accent); font-size: 13px; line-height: 1.5;
      }
      .editor-section { scroll-margin-top: 105px; margin-bottom: 52px; }
      .section-title {
        display: flex; align-items: end; justify-content: space-between; gap: 20px;
        padding-bottom: 12px; border-bottom: 2px solid var(--ink); margin-bottom: 16px;
      }
      .section-title h2 { margin: 0; font-size: 31px; letter-spacing: -.05em; text-transform: uppercase; }
      .add-button, .remove-button {
        border: 1px solid var(--ink); background: transparent; padding: 7px 10px; font-size: 10px; text-transform: uppercase;
      }
      .remove-button { color: #9d1e16; border-color: #9d1e16; }
      .card { margin-bottom: 12px; padding: 18px; border: 1px solid var(--line); background: var(--panel); }
      .card-top { display: flex; justify-content: space-between; align-items: center; margin-bottom: 14px; }
      .card-number { font-size: 10px; color: var(--muted); text-transform: uppercase; }
      .field-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }
      .field { display: flex; flex-direction: column; gap: 6px; }
      .field.full { grid-column: 1 / -1; }
      .field label { font-size: 10px; color: var(--muted); text-transform: uppercase; letter-spacing: .06em; }
      input, textarea, select {
        width: 100%; border: 1px solid var(--line); border-radius: 0; background: #fafaf7;
        color: var(--ink); padding: 10px; outline: 0;
      }
      input:focus, textarea:focus, select:focus { border-color: var(--ink); }
      textarea { min-height: 86px; resize: vertical; line-height: 1.45; }
      .profile-card .field-grid { grid-template-columns: repeat(2, 1fr); }
      .status { position: fixed; right: 20px; bottom: 20px; max-width: 390px; padding: 14px 17px; background: var(--ink); color: white; font-size: 12px; display: none; }
      .status.show { display: block; }
      .help { font-size: 11px; color: var(--muted); margin: -5px 0 12px; }
      @media (max-width: 800px) {
        .editor-header { flex-wrap: wrap; }
        .editor-header p { display: none; }
        .layout { grid-template-columns: 1fr; padding-inline: 14px; }
        .sidebar { position: static; display: grid; grid-template-columns: 1fr 1fr; }
        .field-grid, .profile-card .field-grid { grid-template-columns: 1fr; }
        .field.full { grid-column: auto; }
      }
    </style>
  </head>
  <body>
    <header class="editor-header">
      <h1>Portfolio Editor</h1>
      <p>내용을 수정하고 파일로 저장하세요.</p>
      <a class="preview-link" href="../" target="_blank">사이트 보기 ↗</a>
      <button class="save-button" id="save">수정 파일 저장</button>
    </header>

    <div class="layout">
      <nav class="sidebar" id="sidebar"></nav>
      <main class="editor-main">
        <div class="notice" id="save-notice">
          이 페이지의 변경 내용은 저장 버튼을 누르기 전까지 브라우저에만 있습니다.
          로컬 사이트에서는 <strong>수정 파일 저장</strong>을 누르면 프로젝트에 바로 반영됩니다.
        </div>
        <div id="editor"></div>
      </main>
    </div>
    <div class="status" id="status"></div>

    <script define:vars={{ initialData }}>
      const state = structuredClone(initialData);

      const sectionDefinitions = [
        {
          key: "education",
          title: "Education",
          fields: [
            ["period", "기간"],
            ["title", "학위"],
            ["place", "학교"],
            ["detail", "설명", "textarea"],
          ],
        },
        {
          key: "experience",
          title: "Experience",
          fields: [
            ["period", "기간"],
            ["title", "직위"],
            ["place", "기관"],
            ["detail", "설명", "textarea"],
          ],
        },
        {
          key: "publications",
          title: "Publications",
          fields: [
            ["year", "연도"],
            ["type", "유형"],
            ["title", "논문 제목", "textarea"],
            ["authors", "저자", "textarea"],
            ["venue", "학술지·학회"],
            ["note", "비고"],
            ["link", "논문 URL"],
          ],
        },
        {
          key: "presentations",
          title: "Presentations",
          fields: [
            ["date", "날짜"],
            ["kind", "유형"],
            ["title", "발표 제목", "textarea"],
            ["event", "행사·장소", "textarea"],
          ],
        },
        {
          key: "projects",
          title: "Projects",
          fields: [
            ["number", "번호"],
            ["status", "상태"],
            ["title", "프로젝트명"],
            ["description", "설명", "textarea"],
            ["tags", "태그 (쉼표로 구분)", "list"],
          ],
        },
        {
          key: "news",
          title: "News",
          fields: [
            ["date", "날짜"],
            ["title", "제목"],
            ["text", "내용", "textarea"],
          ],
        },
        {
          key: "memberships",
          title: "Memberships",
          fields: [
            ["period", "기간"],
            ["title", "회원 유형"],
            ["place", "학회·기관"],
          ],
        },
        {
          key: "methods",
          title: "Methods & Skills",
          fields: [
            ["category", "분류"],
            ["items", "항목 (쉼표로 구분)", "list"],
          ],
        },
        {
          key: "languages",
          title: "Languages",
          fields: [
            ["language", "언어"],
            ["level", "수준"],
          ],
        },
        {
          key: "blogPosts",
          title: "Blog & Instagram",
          fields: [
            ["source", "출처"],
            ["date", "날짜"],
            ["title", "제목"],
            ["excerpt", "짧은 설명", "textarea"],
            ["url", "게시물 URL"],
            ["tone", "색상 (sage, clay, blue, gold)"],
          ],
        },
      ];

      const editor = document.querySelector("#editor");
      const sidebar = document.querySelector("#sidebar");
      const status = document.querySelector("#status");

      function escapeHtml(value = "") {
        return String(value)
          .replaceAll("&", "&amp;")
          .replaceAll('"', "&quot;")
          .replaceAll("<", "&lt;")
          .replaceAll(">", "&gt;");
      }

      function fieldHtml(section, index, key, label, type = "text", value = "") {
        const displayValue = type === "list" && Array.isArray(value) ? value.join(", ") : value;
        const full = type === "textarea" || ["title", "authors", "description", "detail", "text", "excerpt", "url"].includes(key);
        const control = type === "textarea"
          ? `<textarea data-section="${section}" data-index="${index}" data-key="${key}">${escapeHtml(displayValue)}</textarea>`
          : `<input data-section="${section}" data-index="${index}" data-key="${key}" data-type="${type}" value="${escapeHtml(displayValue)}">`;
        return `<div class="field ${full ? "full" : ""}"><label>${label}</label>${control}</div>`;
      }

      function renderProfile() {
        return `
          <section class="editor-section" id="profile">
            <div class="section-title"><h2>Profile</h2></div>
            <div class="card profile-card">
              <div class="field-grid">
                ${fieldHtml("site", -1, "name", "영문 이름", "text", state.site.name)}
                ${fieldHtml("site", -1, "shortName", "이니셜", "text", state.site.shortName)}
                ${fieldHtml("site", -1, "role", "직위", "text", state.site.role)}
                ${fieldHtml("site", -1, "institution", "소속", "text", state.site.institution)}
                ${fieldHtml("site", -1, "location", "지역", "text", state.site.location)}
                ${fieldHtml("site", -1, "email", "이메일", "text", state.site.email)}
                ${fieldHtml("site", -1, "intro", "소개", "textarea", state.site.intro)}
                ${fieldHtml("site", -1, "profile", "연구 프로필", "textarea", state.site.profile)}
                ${fieldHtml("site", -1, "interests", "연구 분야 (쉼표로 구분)", "list", state.site.interests)}
              </div>
            </div>
          </section>
          <section class="editor-section" id="links">
            <div class="section-title"><h2>Links</h2></div>
            <div class="card profile-card">
              <div class="field-grid">
                ${Object.entries(state.site.links).map(([key, value]) =>
                  fieldHtml("links", -1, key, key, "text", value)
                ).join("")}
              </div>
            </div>
          </section>`;
      }

      function renderThesis() {
        return `
          <section class="editor-section" id="thesis">
            <div class="section-title"><h2>Master’s Thesis</h2></div>
            <div class="card profile-card">
              <div class="field-grid">
                ${fieldHtml("thesis", -1, "title", "논문 제목", "textarea", state.thesis.title)}
                ${fieldHtml("thesis", -1, "method", "연구 방법", "text", state.thesis.method)}
                ${fieldHtml("thesis", -1, "summary", "요약", "textarea", state.thesis.summary)}
                ${fieldHtml("thesis", -1, "contribution", "핵심 주장", "textarea", state.thesis.contribution)}
              </div>
            </div>
          </section>`;
      }

      function renderCollection(definition) {
        const items = state[definition.key];
        return `
          <section class="editor-section" id="${definition.key}">
            <div class="section-title">
              <h2>${definition.title}</h2>
              <button class="add-button" data-add="${definition.key}">+ 항목 추가</button>
            </div>
            <p class="help">항목 순서는 웹사이트에 표시되는 순서와 같습니다.</p>
            ${items.map((item, index) => `
              <div class="card">
                <div class="card-top">
                  <span class="card-number">${definition.title} ${String(index + 1).padStart(2, "0")}</span>
                  <button class="remove-button" data-remove="${definition.key}" data-index="${index}">삭제</button>
                </div>
                <div class="field-grid">
                  ${definition.fields.map(([key, label, type]) =>
                    fieldHtml(definition.key, index, key, label, type, item[key] ?? "")
                  ).join("")}
                </div>
              </div>
            `).join("")}
          </section>`;
      }

      function render() {
        editor.innerHTML = renderProfile() + renderThesis() + sectionDefinitions.map(renderCollection).join("");
        sidebar.innerHTML = [
          ["profile", "Profile"],
          ["links", "Links"],
          ["thesis", "Master’s Thesis"],
          ...sectionDefinitions.map((item) => [item.key, item.title]),
        ].map(([key, title], index) =>
          `<a href="#${key}"><span>${String(index + 1).padStart(2, "0")}</span>${title}</a>`
        ).join("");
      }

      editor.addEventListener("input", (event) => {
        const input = event.target;
        const section = input.dataset.section;
        const key = input.dataset.key;
        const index = Number(input.dataset.index);
        let value = input.value;
        if (input.dataset.type === "list") {
          value = value.split(",").map((item) => item.trim()).filter(Boolean);
        }
        if (section === "site") state.site[key] = value;
        else if (section === "links") state.site.links[key] = value;
        else if (section === "thesis") state.thesis[key] = value;
        else state[section][index][key] = value;
      });

      editor.addEventListener("click", (event) => {
        const add = event.target.closest("[data-add]");
        const remove = event.target.closest("[data-remove]");
        if (add) {
          const definition = sectionDefinitions.find((item) => item.key === add.dataset.add);
          const empty = Object.fromEntries(definition.fields.map(([key, , type]) => [key, type === "list" ? [] : ""]));
          state[definition.key].push(empty);
          render();
          document.querySelector(`#${definition.key} .card:last-child`)?.scrollIntoView({ behavior: "smooth" });
        }
        if (remove && confirm("이 항목을 삭제할까요?")) {
          state[remove.dataset.remove].splice(Number(remove.dataset.index), 1);
          render();
        }
      });

      function createSource() {
        const order = ["site", "education", "experience", "publications", "presentations", "projects", "news", "memberships", "methods", "languages", "thesis", "blogPosts"];
        return order.map((key) =>
          `export const ${key} = ${JSON.stringify(state[key], null, 2)};\n`
        ).join("\n");
      }

      function showStatus(message) {
        status.textContent = message;
        status.classList.add("show");
        setTimeout(() => status.classList.remove("show"), 5000);
      }

      document.querySelector("#save").addEventListener("click", async () => {
        const source = createSource();
        try {
          const isLocal = ["localhost", "127.0.0.1"].includes(window.location.hostname);
          if (isLocal) {
            const base = window.location.pathname.startsWith("/sunghyun") ? "/sunghyun" : "";
            const response = await fetch(`${base}/__admin-save`, {
              method: "POST",
              headers: { "Content-Type": "application/json" },
              body: JSON.stringify(state),
            });
            const result = await response.json();
            if (!response.ok || !result.ok) {
              throw new Error(result.message || "로컬 파일 저장에 실패했습니다.");
            }
            showStatus("프로젝트에 바로 저장했습니다. 홈페이지를 새로고침해 확인하세요.");
            return;
          }

          if ("showSaveFilePicker" in window) {
            const handle = await window.showSaveFilePicker({
              suggestedName: "site.ts",
              types: [{ description: "TypeScript data file", accept: { "text/plain": [".ts"] } }],
            });
            const writable = await handle.createWritable();
            await writable.write(source);
            await writable.close();
            showStatus("저장했습니다. 로컬 사이트가 자동으로 새로고침됩니다.");
          } else {
            const blob = new Blob([source], { type: "text/plain;charset=utf-8" });
            const link = document.createElement("a");
            link.href = URL.createObjectURL(blob);
            link.download = "site.ts";
            link.click();
            URL.revokeObjectURL(link.href);
            showStatus("site.ts를 다운로드했습니다.");
          }
        } catch (error) {
          if (error.name !== "AbortError") showStatus("저장하지 못했습니다: " + error.message);
        }
      });

      const isLocalEditor = ["localhost", "127.0.0.1"].includes(window.location.hostname);
      if (!isLocalEditor) {
        document.querySelector("#save-notice").innerHTML =
          "공개 사이트에서는 보안상 서버 파일을 직접 바꿀 수 없습니다. <strong>수정 파일 저장</strong>을 누르면 site.ts 파일이 저장되며, 로컬 프로젝트에 덮어쓴 뒤 GitHub에 배포해야 합니다.";
      }

      render();
    </script>
  </body>
</html>
