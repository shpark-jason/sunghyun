---
import BaseLayout from "../layouts/BaseLayout.astro";
import { site, publications, news } from "../data/site";
import syncedNews from "../data/news-articles.json";
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const url = (path: string) => `${base}${path}`;
const sourceNews = news.filter((item) =>
  /^https?:\/\//i.test(item.url || "") &&
  !/^https?:\/\/(dx\.)?doi\.org\//i.test(item.url || "")
);
const currentUrls = new Set(sourceNews.map((item) => item.url));
const currentSyncedNews = syncedNews.filter((item) => currentUrls.has(item.url));
const latestNews = currentSyncedNews.length ? currentSyncedNews : sourceNews;
const imageUrl = (path: string) =>
  path?.startsWith("/") ? `${base}${path}` : path;
---
<BaseLayout>
  <section class="hero shell">
    <div class="hero-copy">
      <p class="hero-role">{site.role}</p>
      <h1>Studying how digital platforms shape <em>participation, inequality, and agency.</em></h1>
      <p class="hero-lede">{site.intro}</p>
      <div class="button-row">
        <a class="button primary" href={url("/publications")}>Explore my research <span>↗</span></a>
        <a class="button text" href={url("/contact")}>Get in touch <span>→</span></a>
      </div>
    </div>
  </section>

  <section class="welcome shell">
    <p class="eyebrow">Hello, and welcome</p>
    <div class="welcome-copy">
      <p>{site.profile}</p>
      <p>This website brings together my academic background, current research agenda, publications, conference activity, and public-facing work on media responsibility and digital rights.</p>
    </div>
  </section>

  <section class="research-strip">
    <div class="shell">
      <p class="eyebrow">Current research interests</p>
      <div class="interest-list">
        {site.interests.slice(0, 3).map((interest, index) => (
          <div><span>0{index + 1}</span><strong>{interest}</strong></div>
        ))}
      </div>
    </div>
  </section>

  <section class="section shell">
    <div class="section-heading">
      <div>
        <p class="eyebrow">Selected work</p>
        <h2>Recent publications</h2>
      </div>
      <a class="arrow-link" href={url("/publications")}>View all publications <span>→</span></a>
    </div>
    <div class="publication-list">
      {publications.slice(0, 3).map((item) => (
        <a class="publication-row" href={item.link}>
          <span class="publication-year">{item.year}</span>
          <span class="publication-main">
            <span class="meta">{item.type} · {item.venue}</span>
            <strong>{item.title}</strong>
            <span>{item.authors}</span>
          </span>
          <span class="row-arrow">↗</span>
        </a>
      ))}
    </div>
  </section>

  {latestNews.length > 0 && <section class="section shell home-news">
    <div class="section-heading">
      <div>
        <p class="eyebrow">Updates</p>
        <h2>Latest news</h2>
      </div>
      <a class="arrow-link" href={url("/news")}>All news <span>→</span></a>
    </div>
    <div class="news-grid">
      {latestNews.slice(0, 3).map((item) => (
        <article class:list={["news-card", { "has-image": item.image }]}>
          {item.image && <img src={imageUrl(item.image)} alt="" loading="lazy" />}
          <div class="news-card-copy">
            <div class="news-card-meta">
              <time>{item.date}</time>
              {item.publisher && <span>{item.publisher}</span>}
            </div>
              <h3>{item.titleEn || item.title}</h3>
              <p>{item.textEn || item.text}</p>
              {item.url && <a href={item.url} target="_blank" rel="noreferrer">Read original ↗</a>}
          </div>
        </article>
      ))}
    </div>
  </section>}

  <section class="closing-cta">
    <div class="shell">
      <p class="eyebrow">Open to conversation</p>
      <h2>Have a question, an idea,<br />or a project in mind?</h2>
      <a class="button light" href={url("/contact")}>Let’s talk <span>↗</span></a>
    </div>
  </section>
</BaseLayout>
